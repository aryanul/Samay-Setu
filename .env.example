# Copy to ".env.local" and fill in values. Restart `npm run dev` after changes.

# MySQL-compatible connection string (TiDB Cloud Serverless is what we use in prod).
# TLS is enabled in code (mysql2 ssl: { minVersion: TLSv1.2, rejectUnauthorized: true })
# so the URL itself does not need an ssl-mode flag.
# Example (TiDB Cloud): mysql://USER.root:PASSWORD@gateway01.<region>.prod.aws.tidbcloud.com:4000/DATABASE
DATABASE_URL=mysql://USER:PASSWORD@HOST:4000/DATABASE

# Used to sign admin cookies and Verified Architect draft cookies after LinkedIn
SESSION_SECRET=use-a-long-random-string-in-production

# LinkedIn OAuth — create an app at https://www.linkedin.com/developers/apps
# Add product "Sign In with LinkedIn using OpenID Connect".
# Under Auth, set Redirect URL to exactly:
#   http://localhost:3000/api/auth/linkedin/callback   (local)
#   https://YOUR_DOMAIN/api/auth/linkedin/callback     (production)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Public site URL — no trailing slash. Must match LinkedIn "Authorized redirect URLs" exactly.
# Local: http://localhost:3000
# Vercel: set to your live URL (e.g. https://samay-setu-five.vercel.app) if it differs from VERCEL_URL.
# If omitted on Vercel, VERCEL_URL is used automatically for OAuth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
